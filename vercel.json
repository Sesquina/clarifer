{
  "git": {
    "deploymentEnabled": {
      "sprint-*": true,
      "main": true
    }
  },
  "github": {
    "silent": false,
    "autoAlias": true
  },
  "crons": [
    {
      "path": "/api/internal/agents/digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/internal/agents/deadline",
      "schedule": "0 8 * * 1"
    }
  ]
}
