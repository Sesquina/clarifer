# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# expo / mobile build artifacts
apps/mobile/.expo/
apps/mobile/test-results/
apps/mobile/dist/
apps/mobile/web-build/

# local editor / agent state
.vscode/
.claude/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
.env.development
.env.production
apps/mobile/.env
# Allow example files to be committed
!.env.example
!apps/mobile/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
supabase/.temp/

# Sentry Config File
.env.sentry-build-plugin

# Supabase CLI local state
.supabase/
test-results/
