# CLARIFER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# ============================================================
# KEYCLOAK (I3 -- identity provider at auth.clarifer.com)
# ============================================================
# Realm: clarifer | Client: clarifer-app (public)
KEYCLOAK_URL=https://auth.clarifer.com
KEYCLOAK_REALM=clarifer
KEYCLOAK_CLIENT_ID=clarifer-app

# ============================================================
# POSTGRESQL via PgBouncer (I2 -- production server)
# Only set when Next.js runs on the production server.
# Leave unset on Vercel -- app uses Supabase DB there.
# ============================================================
DATABASE_URL=postgresql://clarifer_app:[password]@127.0.0.1:6432/clarifer

# ============================================================
# SUPABASE (storage still uses Supabase; DB used as fallback when DATABASE_URL unset)
# ============================================================
# Found at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # NEVER use in client code

# ============================================================
# ANTHROPIC
# ============================================================
# Found at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# UPSTASH REDIS (rate limiting)
# ============================================================
# Found at: upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# BREVO (email)
# ============================================================
# Found at: app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=...
# Rotate in Vercel Production scope after any key rotation

# Brevo SMTP credentials — used for server-side notification emails.
# SMTP bypasses the IP allowlist restriction on the REST API.
# Found at: app.brevo.com → SMTP & API → SMTP tab
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_USER=aaa008001@smtp-brevo.com
BREVO_SMTP_PASS=your-brevo-smtp-password

# ============================================================
# SENTRY (error monitoring)
# ============================================================
# Found at: sentry.io → your project → Settings → SDK
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Clarifer
# Production origin used as the OAuth redirectTo base — must match an entry in
# Supabase Auth > URL Configuration > Redirect URLs (e.g. https://clarifer.com/auth/callback)
NEXT_PUBLIC_SITE_URL=https://clarifer.com

# ============================================================
# POSTHOG (analytics)
# ============================================================
# Found at: app.posthog.com → your project → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# HQ DASHBOARD (/hq -- formerly /internal)
# ============================================================
# Shared passcode for clarifer.com/hq/login
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Scope in Vercel: Production only. Never Preview or Development.
INTERNAL_PASSCODE=your-chosen-passcode-here

# API secret for cron agents (separate from the login passcode)
INTERNAL_API_SECRET=generate-with-openssl-rand-hex-32

# GitHub webhook (Settings > Webhooks > Add webhook)
# Events: Workflow runs only. Payload URL: /api/hq/github-webhook
GITHUB_WEBHOOK_SECRET=set-when-configuring-github-webhook

# Base URL for internal agents posting back to themselves
CLARIFER_INTERNAL_URL=https://clarifer.com
